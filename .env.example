# VPS Integration API - Environment Variables

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=false
LOG_LEVEL=info

# Application
APP_NAME="VPS Integration API"
APP_VERSION="1.0.0"
DEBUG=false

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=https://your-domain.com/auth/github/callback
GITHUB_AUTHORIZE_URL=https://github.com/login/oauth/authorize
GITHUB_TOKEN_URL=https://github.com/login/oauth/access_token
GITHUB_USER_API_URL=https://api.github.com/user

# Allowed Users (comma-separated GitHub usernames)
ALLOWED_USERS=user1,user2,user3

# CORS
CORS_ORIGINS=https://your-domain.com,http://localhost:3000
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_STORAGE=memory

# Docker
DOCKER_SOCKET=/var/run/docker.sock
DOCKER_API_VERSION=auto

# File Operations
ALLOWED_PATHS=/data,/var/log,/etc/nginx,/tmp
FORBIDDEN_PATHS=/etc/passwd,/etc/shadow,/root,/etc/ssh
MAX_FILE_SIZE=10485760  # 10MB

# System Monitoring
MONITOR_INTERVAL=5
METRICS_ENABLED=true

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_FORMAT=json
LOG_FILE=/var/log/vps-api.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5